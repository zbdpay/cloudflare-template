{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["@cloudflare/workers-types"],
    "paths": { "@/*": ["./src/*"] }
  },
  "include": ["src/**/*", "worker/**/*"]
}
